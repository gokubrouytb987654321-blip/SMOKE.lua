local function makePart(parent, size, color, cf, transparency, material)
	local p = Instance.new("Part")
	p.Size = size
	p.Color = color
	p.Material = material or Enum.Material.SmoothPlastic
	p.CanCollide = false
	p.Massless = true
	p.Anchored = false
	p.Transparency = transparency or 0
	p.CFrame = cf
	p.Parent = parent
	return p
end

local function weldTo(a, b)
	local w = Instance.new("WeldConstraint")
	w.Part0 = a
	w.Part1 = b
	w.Parent = a
	return w
end

local vapeModel = Instance.new("Model")
