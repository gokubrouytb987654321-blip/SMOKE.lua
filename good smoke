-- =====================
-- FUMÉE
-- =====================
local function bigSmoke()
	local att = Instance.new("Attachment")
	att.Position = Vector3.new(0, -0.1, -0.8)
	att.Parent = head

	local configs = {
		{rate=700, life={3,7},  spd={4,8}, size=15, spread=20, c1=Color3.fromRGB(220,240,255), c2=Color3.fromRGB(255,255,255)},
		{rate=400, life={4,9},  spd={2,5}, size=28, spread=35, c1=Color3.fromRGB(180,215,255), c2=Color3.fromRGB(240,248,255)},
		{rate=250, life={5,11}, spd={1,3}, size=42, spread=50, c1=Color3.fromRGB(100,160,255), c2=Color3.fromRGB(210,230,255)},
		{rate=120, life={6,13}, spd={1,2}, size=60, spread=65, c1=Color3.fromRGB(60,120,230),  c2=Color3.fromRGB(190,220,255)},
	}

	local emitters = {}
	for _, c in ipairs(configs) do
		local e = Instance.new("ParticleEmitter")
		e.Texture = "rbxasset://textures/particles/smoke_main.dds"
		e.Rate = c.rate
		e.Lifetime = NumberRange.new(c.life[1], c.life[2])
		e.Speed = NumberRange.new(c.spd[1], c.spd[2])
		e.Size = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(0.3, c.size * 0.4),
			NumberSequenceKeypoint.new(1, c.size),
		})
		e.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0),
			NumberSequenceKeypoint.new(0.4, 0.35),
			NumberSequenceKeypoint.new(1, 1),
		})
		e.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, c.c1),
			ColorSequenceKeypoint.new(1, c.c2),
		})
		e.SpreadAngle = Vector2.new(c.spread, c.spread)
		e.RotSpeed = NumberRange.new(-25, 25)
		e.Rotation = NumberRange.new(0, 360)
		e.LightEmission = 0.5
		e.Acceleration = Vector3.new(0, 14, -3)
		e.Parent = att
		table.insert(emitters, e)
	end

	task.delay(3, function()
		for _, e in ipairs(emitters) do e.Enabled = false end
		task.wait(13)
		att:Destroy()
	end)
end

