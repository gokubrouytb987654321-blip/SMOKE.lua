local bandTop = makePart(vapeModel, Vector3.new(0.36, 0.06, 0.36), Color3.fromRGB(0, 20, 120), body.CFrame * CFrame.new(0, 0.15, 0))
local bandBot = makePart(vapeModel, Vector3.new(0.36, 0.06, 0.36), Color3.fromRGB(0, 20, 120), body.CFrame * CFrame.new(0, -0.36, 0))
local cap = makePart(vapeModel, Vector3.new(0.28, 0.25, 0.28), Color3.fromRGB(5, 20, 110), body.CFrame * CFrame.new(0, 0.72, 0))
